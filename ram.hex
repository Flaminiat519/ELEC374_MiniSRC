@00A
D0000000  // nop                 ; no operation
@00B
A8900002  // brpl R1, 2          ; R1 is positive, branch to 0x00E (target)
@00C
89A80007  // ldi R3, 7(R5)       ; NOT EXECUTED (skipped by brpl)
@00D
