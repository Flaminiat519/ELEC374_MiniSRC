@027
8D880005  // ldi R11, 5(R1)      ; R11 = 0 + 5 = 5
@028
A5600000  // jal R10             ; R12 = 0x029, PC = R10 = 0xB2
@029
9E000000  // halt                ; program halts on return
@089
000000A7  // [data] M[0x89] = 0xA7 (initial value)
@0A3
00000068  // [data] M[0xA3] = 0x68 (initial value)
@0B2
