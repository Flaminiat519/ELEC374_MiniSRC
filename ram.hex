@00F
48880003  // addi R1, R1, 3      ; R1 = 0xA7 + 3 = 0xAA
@010
70880000  // neg R1, R1          ; R1 = -0xAA = 0xFFFFFF56
@011
78880000  // not R1, R1          ; R1 = ~0xFFFFFF56 = 0xA9
@012
5088000F  // andi R1, R1, 0xF    ; R1 = 0xA9 & 0xF = 0x9
@013
3A010000  // ror R4, R0, R2      ; R4 = ror(0x68, 4) = 0x80000006
@014
58A00005  // ori R1, R4, 5       ; R1 = 0x80000006 | 5 = 0x80000007
@015
2A090000  // shra R4, R1, R2     ; R4 = shra(0x80000007, 4) = 0xF8000000
@016
22A90000  // shr R5, R5, R2      ; R5 = 0x8C >> 4 = 0x8
@017
928000A3  // st 0xA3, R5         ; M[0xA3] = 0x8
@018
42810000  // rol R5, R0, R2      ; R5 = rol(0x68, 4) = 0x680
@019
1B900000  // or R7, R2, R0       ; R7 = 4 | 0x68 = 0x6C
@01A
12280000  // and R4, R5, R0      ; R4 = 0x680 & 0x68 = 0x0
@01B
93A00089  // st 0x89(R4), R7     ; M[0x89 + 0] = M[0x89] = 0x6C
@01C
082B8000  // sub R0, R5, R7      ; R0 = 0x680 - 0x6C = 0x614
@01D
32290000  // shl R4, R5, R2      ; R4 = 0x680 << 4 = 0x6800
@01E
8B800007  // ldi R7, 7           ; R7 = 7
@01F
89800019  // ldi R3, 0x19        ; R3 = 0x19
@020
69B80000  // mul R3, R7          ; HI:LO = 0x19 * 7 = 0xAF
@021
C0800000  // mfhi R1             ; R1 = HI = 0x0
@022
CB000000  // mflo R6             ; R6 = LO = 0xAF
@023
61B80000  // div R3, R7          ; HI = 0x19 % 7 = 4, LO = 0x19 / 7 = 3
@024
8C380002  // ldi R8, 2(R7)       ; R8 = 7 + 2 = 9
@025
8C9FFFFC  // ldi R9, -4(R3)      ; R9 = 0x19 - 4 = 0x15
@026
